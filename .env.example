# MATRIX standalone app configuration
# Production: copy from production-setup.sh output or set MATRIX_ENV=production

MATRIX_ENV=production
MATRIX_DATA_DIR=/Users/you/.matrix

# Semicolon-separated archive roots (macOS)
MATRIX_SCAN_ROOTS=/Volumes/Photos:/Volumes/Archive

# Quarantine folder — rejected duplicates are MOVED here, never hard-deleted
MATRIX_QUARANTINE=/Users/you/.matrix/quarantine

# pHash Hamming distance threshold for visual duplicates (default 10)
MATRIX_PHASH_MAX_DISTANCE=10

# API (matrix serve)
MATRIX_API_HOST=127.0.0.1
MATRIX_API_PORT=8765
# Optional Bearer token for /api/* (Authorization: Bearer <token>)
MATRIX_API_TOKEN=

# Safety limits
MATRIX_MAX_HASH_BYTES=536870912
MATRIX_MAX_XMP_BYTES=33554432